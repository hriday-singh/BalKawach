FROM python:3.10-slim

WORKDIR /app

# Install system dependencies for audio processing
RUN apt-get update && apt-get install -y --no-install-recommends \
    libsndfile1 \
    ffmpeg \
    && rm -rf /var/lib/apt/lists/*

COPY requirements-transcription.txt .
RUN pip install --no-cache-dir -r requirements-transcription.txt

# Install matching CPU torch/torchaudio LAST so nothing downstream can override them
RUN pip install --no-cache-dir --force-reinstall torch torchaudio --index-url https://download.pytorch.org/whl/cpu

# Sanity check at build time - fails the build loudly instead of at runtime
RUN python -c "import torch, torchaudio; print(torch.__version__, torchaudio.__version__)" && pip check

# Copy only the transcription server code (not the entire repo)
COPY transcription_server/ transcription_server/

# Create uploads directory
RUN mkdir -p uploads data

EXPOSE 9121

# Download model then start server
CMD python -m transcription_server.download_model && python -m transcription_server.main
