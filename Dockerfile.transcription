FROM python:3.10-slim

WORKDIR /app

# Install system dependencies for audio processing
RUN apt-get update && apt-get install -y --no-install-recommends \
    libsndfile1 \
    ffmpeg \
    && rm -rf /var/lib/apt/lists/*

# Install PyTorch CPU first to avoid pulling down massive CUDA binaries
RUN pip install --no-cache-dir torch==2.3.1 torchaudio==2.3.1 --index-url https://download.pytorch.org/whl/cpu

COPY requirements-transcription.txt .
RUN pip install --no-cache-dir -r requirements-transcription.txt --extra-index-url https://download.pytorch.org/whl/cpu

# Copy only the transcription server code (not the entire repo)
COPY transcription_server/ transcription_server/

# Create uploads directory
RUN mkdir -p uploads data

EXPOSE 9121

# Download model then start server
CMD python -m transcription_server.download_model && python -m transcription_server.main
