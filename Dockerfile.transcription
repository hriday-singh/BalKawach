FROM python:3.10-slim

WORKDIR /app

# Install system dependencies for audio processing
RUN apt-get update && apt-get install -y --no-install-recommends \
    libsndfile1 \
    ffmpeg \
    && rm -rf /var/lib/apt/lists/*

COPY requirements-transcription.txt .
# Install PyTorch CPU and requirements together (no fixed versions), prioritizing CPU index
RUN pip install --no-cache-dir torch torchaudio -r requirements-transcription.txt \
    --index-url https://download.pytorch.org/whl/cpu \
    --extra-index-url https://pypi.org/simple

# Copy only the transcription server code (not the entire repo)
COPY transcription_server/ transcription_server/

# Create uploads directory
RUN mkdir -p uploads data

EXPOSE 9121

# Download model then start server
CMD python -m transcription_server.download_model && python -m transcription_server.main
